<%- include("partials/header") %>

<div class="page-header">
  <div>
    <h1>Ny faktura</h1>
    <p>Opret en PMV-faktura uden moms.</p>
  </div>
</div>

<% if (!customers.length) { %>
  <div class="alert error">
    Du skal oprette mindst én kunde først. <a href="<%= basePath %>/customers">Opret kunde</a>
  </div>
<% } else { %>
<section class="card">
  <form method="post" action="<%= basePath %>/invoices" class="form">
    <div class="grid-form">
      <label>
        Kunde
        <select name="customer_id" required>
          <% customers.forEach(customer => { %>
            <option value="<%= customer.id %>"><%= customer.name %></option>
          <% }) %>
        </select>
      </label>
      <label>Fakturadato <input name="issue_date" type="date" value="<%= issueDate %>" required></label>
      <label>Forfaldsdato <input name="due_date" type="date" value="<%= dueDate %>" required></label>
      <label>
        Status
        <select name="status">
          <option value="draft">Kladde</option>
          <option value="sent">Sendt</option>
          <option value="paid">Betalt</option>
        </select>
      </label>
    </div>

    <h2>Linjer</h2>
    <div id="items" class="items">
      <div class="item-row">
        <input name="description" placeholder="Beskrivelse" required>
        <input name="quantity" type="number" step="0.01" value="1" required>
        <input name="unit_price" type="number" step="0.01" placeholder="Pris" required>
      </div>
    </div>

    <button type="button" class="secondary" onclick="addItem()">Tilføj linje</button>

    <label>
      Note på faktura
      <textarea name="notes" rows="3"></textarea>
    </label>

    <button type="submit">Opret faktura</button>
  </form>
</section>
<% } %>

<script>
function addItem() {
  const div = document.createElement("div");
  div.className = "item-row";
  div.innerHTML = `
    <input name="description" placeholder="Beskrivelse" required>
    <input name="quantity" type="number" step="0.01" value="1" required>
    <input name="unit_price" type="number" step="0.01" placeholder="Pris" required>
  `;
  document.getElementById("items").appendChild(div);
}
</script>

<%- include("partials/footer") %>
